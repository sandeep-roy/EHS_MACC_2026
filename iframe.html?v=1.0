<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Marginal Abatement Cost Curve</title>

  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      font-family: Arial, sans-serif;
    }

    #svg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }

    #tooltip {
      position: absolute;
      background: rgba(0, 0, 0, 0.85);
      color: #fff;
      padding: 6px 10px;
      border-radius: 4px;
      font-size: 12px;
      pointer-events: none;
      display: none;
      max-width: 300px;
      z-index: 100;
      line-height: 1.3em;
    }

    /* UI: Zoom controls */
    #zoom-controls {
      position: absolute;
      top: 10px;
      right: 40px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      z-index: 200;
    }

    #zoom-controls button {
      width: 32px;
      height: 32px;
      border: 1px solid #444;
      background: white;
      font-weight: bold;
      font-size: 18px;
      cursor: pointer;
      border-radius: 4px;
    }

    #zoom-controls button:hover {
      background: #e9e9e9;
    }
  </style>
</head>

<body>

<div id="zoom-controls">
  <button id="zoom-in">+</button>
  <button id="zoom-out">−</button>
  <button id="zoom-reset">⟳</button>
  <button id="zoom-box">▭</button>
  <button id="toggle-curve">👁</button
</div>

<div id="tooltip"></div>
<svg id="svg"></svg>

<script type="module">
  import { initMACC } from "./src/main.js";
  initMACC();
</script>

</body>
</html>
